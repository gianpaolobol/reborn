APP_ENV=testing
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

DB_CONNECTION=sqlite
DB_DATABASE=storage/database/reborn.sqlite

API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

AUTH_TOKEN_TTL_SECONDS=604800
AUTH_DEFAULT_ROLE=repair_user

SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=5000
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_BYTES=15728640
TRUSTED_PROXY_HEADERS=false

# CI-only safety net: demo accounts may log in with password=password even if an old seed hash is stale.
DEMO_AUTH_FALLBACK_ENABLED=true


# Step 50 — Cloud free multi-provider recognition
# CI keeps external providers unconfigured; smoke scripts still use deterministic_smoke and never depend on live cloud quotas.
AI_PHOTO_RECOGNITION_PROVIDER=auto
AI_PHOTO_RECOGNITION_ENABLED=true
AI_VISION_PROVIDER_ORDER=ocrspace,groq,openrouter

OCRSPACE_ENABLED=true
OCRSPACE_API_KEY=
OCRSPACE_BASE_URL=https://api.ocr.space/parse/image
OCRSPACE_LANGUAGE=eng
OCRSPACE_ENGINE=2
OCRSPACE_TIMEOUT_SECONDS=45

GROQ_ENABLED=true
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TIMEOUT_SECONDS=90
GROQ_MAX_OUTPUT_TOKENS=2500
GROQ_TEMPERATURE=0.1

OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=90
OPENROUTER_MAX_OUTPUT_TOKENS=2500
OPENROUTER_TEMPERATURE=0.1

# Optional paid/quota-limited cloud fallbacks. Keep disabled/empty for the free-cloud demo flow.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=90
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TEMPERATURE=0.1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=90
OPENAI_VISION_MAX_IMAGES=8
OPENAI_VISION_MAX_IMAGE_BYTES=20971520
OPENAI_VISION_DETAIL=original
OPENAI_VISION_WEB_SEARCH_ENABLED=true
OPENAI_REASONING_EFFORT=high
OPENAI_VISION_MAX_OUTPUT_TOKENS=4500
