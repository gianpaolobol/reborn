APP_ENV=development
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

DB_CONNECTION=sqlite
DB_DATABASE=storage/database/reborn.sqlite

API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

AUTH_TOKEN_TTL_SECONDS=604800
AUTH_DEFAULT_ROLE=repair_user

# Step 20 production readiness hardening
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_BYTES=15728640
TRUSTED_PROXY_HEADERS=false

# Local/dev fallback for demo accounts only. Keep false in production.
DEMO_AUTH_FALLBACK_ENABLED=false
